# ============================================================
# Etanetas Address API — environment variables
# Copy to .env and fill in the values.
# ============================================================

# --- Database (required) ---
DB_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://etanetas:change_me@localhost:5432/etanetas_addresses_coverage

# --- CORS (development includes localhost frontend) ---
# Comma-separated list of trusted origins. For production, keep only public domains.
CORS_ORIGINS=https://etanetas.lt,https://www.etanetas.lt,http://localhost:3000,http://127.0.0.1:3000

# --- Dashboard scope (optional) ---
# Domyślnie statystyki ograniczone do obszaru operacyjnego ISP (kody RC savivaldybi).
# STATS_MUNICIPALITY_CODES=13,41,85
# STATS_MUNICIPALITY_NAMES=Vilniaus miesto,Vilniaus rajono,Šalčininkų rajono

# --- Security ---
# bcrypt work factor for API key hashing (default 12; lower only for dev/test)
# BCRYPT_ROUNDS=12

# --- Connection pool ---
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10

# --- ETL data sources (required for ETL to work) ---
SPINTA_BASE_URL=https://get.data.gov.lt/datasets/gov/rc/ar
RC_GEOJSON_URL=https://www.registrucentras.lt/aduomenys/?byla=adr_gra_adresai_LT.zip

# --- Telegram alerts (optional — leave empty to disable) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ---
# LOG_LEVEL=INFO
# LOG_FILE=/var/log/etanetas/api.log   (omit for stdout-only)
# LOG_FORMAT=text                       (text | json)

# --- OpenTelemetry ---
# OTEL_EXPORTER=console       (console | otlp | none)
# OTEL_SERVICE_NAME=etanetas-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# === Optional ETL tuning (defaults work for most cases) ===
# SPINTA_TIMEOUT_SECONDS=120.0
# SPINTA_CONNECT_TIMEOUT_SECONDS=10.0
# SPINTA_MAX_RETRIES=10
# SPINTA_FETCH_LIMIT=5000

# RC direct file downloads
# RC_DOWNLOAD_TIMEOUT_SECONDS=300.0
# RC_DOWNLOAD_CONNECT_TIMEOUT_SECONDS=10.0
# RC_DOWNLOAD_MAX_RETRIES=5

# ETL infrastructure
# ETL_CACHE_DIR=etl/state/cache
# UPSERT_BATCH_SIZE=10000
# STALE_SYNC_DAYS=7
